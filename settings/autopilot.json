{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(app/**)",
      "Edit(apps/**)",
      "Edit(packages/**)",
      "Edit(crates/**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(app/**)",
      "Write(apps/**)",
      "Write(packages/**)",
      "Write(crates/**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm -r test:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm run typecheck:*)",
      "Bash(pnpm -r typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm -r build:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npx tsc:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:nodejs.org)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm dlx:*)",
      "Bash(npm install:*)",
      "Bash(npx:*)",
      "Bash(cargo add:*)",
      "Bash(curl:*)",
      "Bash(git reset --hard:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/secrets/**)"
    ]
  }
}
